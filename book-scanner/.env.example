# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=bookscanner
POSTGRES_USER=bookuser
POSTGRES_PASSWORD=bookpass

# ─── Tesseract OCR (geen API key nodig — draait lokaal in Docker) ────────────
# Taaldata wordt automatisch geïnstalleerd via de Dockerfile (eng + nld)
# Voeg extra talen toe door de waarde uit te breiden, bijv: eng+nld+fra
TESSDATA_LANG=eng+nld

# ─── Kafka (intern, alleen aanpassen als je de poorten wil wijzigen) ──────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
