# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=bookscanner
POSTGRES_USER=bookuser
POSTGRES_PASSWORD=bookpass

# ─── Google Cloud Vision API ──────────────────────────────────────────────────
# Stap 1: Ga naar https://console.cloud.google.com/
# Stap 2: Maak een project aan en activeer de "Cloud Vision API"
# Stap 3: Maak een API key aan via "APIs & Services" → "Credentials"
# Stap 4: Plak de key hier
GOOGLE_VISION_API_KEY=your_google_vision_api_key_here

# ─── Kafka (intern, alleen aanpassen als je de poorten wil wijzigen) ──────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
